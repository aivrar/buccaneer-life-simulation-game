# LLM Provider — 'local' for llama-server, 'openrouter' for cloud API
LLM_PROVIDER=local
VLLM_URL=http://127.0.0.1:8081/v1
VLLM_MODEL=qwen35-9b

# OpenRouter (optional — only if LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your-key-here
# OPENROUTER_LLM_MODEL=google/gemini-2.5-flash

# Database
SQLITE_PATH=./game.db

# Simulation
SIM_TICK_INTERVAL_MS=0
SIM_MAX_CONCURRENT_LLM=20
SIM_LOG_LEVEL=events
