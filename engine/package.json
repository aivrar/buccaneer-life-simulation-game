{
  "name": "llama-game-engine",
  "version": "0.1.0",
  "description": "AI agent game engine powered by llama.cpp",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "play": "tsx src/play.ts",
    "poc": "tsx src/poc.ts",
    "stress": "tsx src/stress.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.7",
    "mysql2": "^3.20.0",
    "sql.js": "^1.14.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
